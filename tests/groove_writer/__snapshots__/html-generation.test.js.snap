	<input checked type="checkbox" class="myCheckbox" id="PermuationOptionsSingles_sub3" onClick="myGrooveWriter.permutationSubOptionClick(event)">	<label for="PermuationOptionsSingles_sub3">&</label></span><span class="PermutationSubOption">
	<input checked type="checkbox" class="myCheckbox" id="PermuationOptionsSingles_sub4" onClick="myGrooveWriter.permutationSubOptionClick(event)">	<label for="PermuationOptionsSingles_sub4">a</label></span>	</span>
</div>
<div class="PermutationOptionGroup" id="PermuationOptionsDoublesGroup">
<div class="PermutationOption">
<input checked type="checkbox" class="myCheckbox" id="PermuationOptionsDoubles" onClick="myGrooveWriter.permutationOptionClick(event)"><label for="PermuationOptionsDoubles">Doubles</label>
</div><span class="permutationSubOptionContainer" id="PermuationOptionsDoubles_sub">
<span class="PermutationSubOption">
