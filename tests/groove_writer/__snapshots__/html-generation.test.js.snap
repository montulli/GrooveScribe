exports[`HTMLforPermutationOptions > "kick_16ths" permutation type (straight 4/4, default 16th division) > renders the Skip-first-notes, Ostinato, Singles, Doubles, Downbeats/Upbeats, Triples and Quads groups 1`] = `
"<span id="PermutationOptionsHeader">Permutation Options</span>
<span class="PermutationOptionWrapper"><div class="PermutationOptionGroup" id="PermuationOptionsSkipSomeFirstNotesGroup">
<div class="PermutationOption">
<input  type="checkbox" class="myCheckbox" id="PermuationOptionsSkipSomeFirstNotes" onClick="myGrooveWriter.permutationOptionClick(event)"><label for="PermuationOptionsSkipSomeFirstNotes">Simplify multiple kicks</label>
</div><span class="permutationSubOptionContainer" id="">
	</span>
</div>
<div class="PermutationOptionGroup" id="PermuationOptionsOstinatoGroup">
<div class="PermutationOption">
<input  type="checkbox" class="myCheckbox" id="PermuationOptionsOstinato" onClick="myGrooveWriter.permutationOptionClick(event)"><label for="PermuationOptionsOstinato">Ostinato</label>
</div><span class="permutationSubOptionContainer" id="PermuationOptionsOstinato_sub">
	</span>
</div>
<div class="PermutationOptionGroup" id="PermuationOptionsSinglesGroup">
<div class="PermutationOption">
<input checked type="checkbox" class="myCheckbox" id="PermuationOptionsSingles" onClick="myGrooveWriter.permutationOptionClick(event)"><label for="PermuationOptionsSingles">Singles</label>
</div><span class="permutationSubOptionContainer" id="PermuationOptionsSingles_sub">
<span class="PermutationSubOption">
	<input checked type="checkbox" class="myCheckbox" id="PermuationOptionsSingles_sub1" onClick="myGrooveWriter.permutationSubOptionClick(event)">	<label for="PermuationOptionsSingles_sub1">1</label></span><span class="PermutationSubOption">
