	<input checked type="checkbox" class="myCheckbox" id="PermuationOptionsDoubles_sub4" onClick="myGrooveWriter.permutationSubOptionClick(event)">	<label for="PermuationOptionsDoubles_sub4">a</label></span>	</span>
</div>
<div class="PermutationOptionGroup" id="PermuationOptionsUpsDownsGroup">
